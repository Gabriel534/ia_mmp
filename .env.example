GROQ_API_KEY=your_groq_api_key_here


# ==========================================
# MYSQL - BANCO DE DADOS RELACIONAL
# ==========================================
DB_HOST=db_mmp
DB_PORT=3306
DB_USER=app_mmp
DB_PASS=app_mmp
