# ==========================================
# CREDENCIAIS
# ==========================================
# Grok API Token (obrigatório)
# Obtenha em: https://grok.ai/settings/tokens
GROQ_API_KEY=your_groq_api_key_here


# ==========================================
# QDRANT - VECTOR DATABASE
# ==========================================
# Host do servidor Qdrant
QDRANT_HOST=qdrant

# Porta HTTP do Qdrant
QDRANT_PORT=6333

# Nome da coleção no Qdrant
QDRANT_COLLECTION=documents


# ==========================================
# MYSQL - BANCO DE DADOS RELACIONAL
# ==========================================
# Host do servidor MySQL
DB_HOST=db_mmp

# Porta do MySQL
DB_PORT=3306

# Usuário do MySQL
DB_USER=app_mmp

# Senha do MySQL
DB_PASS=app_mmp

# Nome do banco de dados
DB_NAME=db_mmp


# ==========================================
# MODELOS E LLM
# ==========================================
# Modelo de embeddings
EMBEDDINGS_MODEL=sentence-transformers/all-mpnet-base-v2

# Modelo LLM do Groq
LLM_MODEL=llama-3.3-70b-versatile


# ==========================================
# CHUNKING - PROCESSAMENTO DE DOCUMENTOS
# ==========================================
# Tamanho de cada chunk de texto
CHUNK_SIZE=1000

# Overlap entre chunks (para manter contexto)
CHUNK_OVERLAP=150


# ==========================================
# RETRIEVAL
# ==========================================
# Número de documentos a recuperar
RETRIEVER_K=4


# ==========================================
# DEBUG
# ==========================================
DEBUG=False
LOG_LEVEL=INFO

